# Datenbank
DATABASE_URL=postgresql://zeitkapsel:zeitkapsel@localhost:5432/zeitkapsel

# Auth.js
AUTH_SECRET=dein-geheimes-secret-hier-ersetzen
AUTH_URL=http://localhost:3000

# Resend (E-Mail-Versand)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@zeitkapsel.ch

# Datei-Upload (lokal oder Cloudflare R2)
UPLOAD_PROVIDER=local
UPLOAD_DIR=./uploads

# Cloudflare R2 (optional, für Produktion)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=zeitkapsel

# App-URLs
API_URL=http://localhost:4000
WEB_URL=http://localhost:3000

# Umgebung
NODE_ENV=development
